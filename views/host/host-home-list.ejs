<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main style="max-width: 1320px; margin: 0 auto; padding: 2rem 1.5rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h1 style="font-size: 2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.3rem;">My <span class="brand-text">Properties</span></h1>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Manage your listed properties on StayEG</p>
        </div>
        <a href="/host/add-home" class="btn-primary" style="text-decoration: none;"><i class="fa-solid fa-plus"></i> Add Property</a>
      </div>

      <% if (registeredHomes.length > 0) { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
          <% registeredHomes.forEach(home => { %>
            <div class="stay-card" style="display: flex; flex-direction: column;">
              <div style="position: relative; height: 200px; overflow: hidden;">
                <img src="/<%= home.photo %>" alt="<%= home.houseName %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease;">
                <div style="position: absolute; top: 0.75rem; right: 0.75rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); padding: 0.3rem 0.6rem; border-radius: 0.5rem; display: flex; align-items: center; gap: 0.3rem;">
                  <i class="fa-solid fa-star" style="color: #f59e0b; font-size: 0.7rem;"></i>
                  <span style="font-weight: 700; color: white; font-size: 0.8rem;"><%= home.rating %></span>
                </div>
              </div>
              <div style="padding: 1.25rem; flex: 1; display: flex; flex-direction: column;">
                <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.35rem;"><%= home.houseName %></h3>
                <p style="font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.5rem;">
                  <i class="fa-solid fa-location-dot" style="color: var(--primary);"></i> <%= home.location %>
                </p>
                <div style="display: flex; gap: 1rem; margin-bottom: 0.75rem;">
                  <span style="font-size: 0.8rem; color: var(--text-muted);"><i class="fa-solid fa-bed" style="margin-right: 0.3rem;"></i><%= home.bedrooms %> bed</span>
                  <span style="font-size: 0.8rem; color: var(--text-muted);"><i class="fa-solid fa-users" style="margin-right: 0.3rem;"></i><%= home.guests %> guests</span>
                </div>
                <div style="padding-top: 0.75rem; border-top: 1px solid var(--border); margin-top: auto;">
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                    <span style="font-size: 1.2rem; font-weight: 800; color: var(--primary);">₹<%= home.price.toLocaleString() %> <span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted);">/ night</span></span>
                  </div>
                  <div style="display: flex; gap: 0.5rem;">
                    <a href="/host/edit-home/<%= home._id %>?editing=true" class="btn-secondary" style="flex: 1; text-decoration: none; font-size: 0.85rem; padding: 0.55rem;">
                      <i class="fa-solid fa-pen"></i> Edit
                    </a>
                    <form action="/host/delete-home/<%= home._id %>" method="POST" style="flex-shrink: 0;" onsubmit="return confirm('Are you sure you want to delete this property?');">
                      <button type="submit" class="btn-danger" style="font-size: 0.85rem; padding: 0.55rem 0.75rem;">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div style="text-align: center; padding: 4rem 2rem; background: var(--bg-card); border-radius: 1rem; border: 1px solid var(--border);">
          <i class="fa-solid fa-building" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;"></i>
          <p style="font-size: 1.2rem; color: var(--text-secondary); margin-bottom: 0.5rem;">No properties listed yet</p>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Start earning by listing your first property</p>
          <a href="/host/add-home" class="btn-primary" style="text-decoration: none;">List Property</a>
        </div>
      <% } %>
    </main>
  </body>
</html>
