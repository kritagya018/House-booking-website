<%- include('../partials/head') %>
  </head>
  <body class="bg-slate-50">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-4 py-12 max-w-7xl">
      <div class="mb-10 flex flex-col items-center">
        <div class="w-16 h-16 bg-rose-100 rounded-full flex items-center justify-center mb-4">
          <i class="fa-solid fa-heart text-rose-500 text-3xl"></i>
        </div>
        <h2 class="text-4xl md:text-5xl font-extrabold text-slate-800 tracking-tight">
          Your <span class="gradient-text">Favourites</span>
        </h2>
      </div>

      <% if (favouriteHomes.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          <% favouriteHomes.forEach(home => { %>
            <div class="bg-white rounded-2xl overflow-hidden card-hover border border-slate-100 relative group flex flex-col h-full">
              <a href="/homes/<%= home._id %>" class="block flex-grow">
                <div class="relative h-56 overflow-hidden">
                  <img src="/<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                  <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
                    <i class="fa-solid fa-star text-yellow-500 text-sm"></i>
                    <span class="font-bold text-slate-800 text-sm"><%= home.rating %></span>
                  </div>
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <h3 class="text-xl font-bold text-slate-800 truncate mb-1"><%= home.houseName %></h3>
                  <p class="text-slate-500 mb-4 flex items-center text-sm font-medium">
                    <i class="fa-solid fa-location-dot mr-2 text-slate-400"></i><%= home.location %>
                  </p>
                  <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center">
                    <div>
                      <span class="text-2xl font-extrabold text-slate-800">Rs <%= home.price %></span>
                      <span class="text-slate-500 text-sm font-medium"> / night</span>
                    </div>
                  </div>
                </div>
              </a>
              <div class="px-6 pb-6 pt-0 flex gap-3">
                <a href="/homes/<%= home._id %>" class="btn-gradient text-white flex-1 text-center py-3 rounded-xl font-bold">
                  Details
                </a>
                <form action="/favourites/delete/<%= home._id %>" method="POST" class="flex-none">
                  <button type="submit" class="bg-slate-100 text-slate-500 hover:bg-rose-50 hover:text-rose-600 p-3 rounded-xl transition-colors h-full flex items-center justify-center w-12">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="bg-white rounded-3xl p-12 text-center max-w-2xl mx-auto border border-slate-100 shadow-sm mt-8">
          <i class="fa-regular fa-heart text-6xl text-slate-200 mb-4"></i>
          <p class="text-2xl text-slate-700 font-medium mb-4">No favourites yet!</p>
          <p class="text-slate-500 mb-8">Browse our homes and tap the heart icon to save them here.</p>
          <a href="/homes" class="btn-gradient text-white px-8 py-3 rounded-full font-bold">Explore Homes</a>
        </div>
      <% } %>
    </main>
  </body>
</html>
