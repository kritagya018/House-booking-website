<%- include('../partials/head') %>
  </head>
  <body class="bg-slate-50">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-4 py-12 max-w-7xl">
      <div class="mb-10 text-center max-w-3xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-extrabold text-slate-800 mb-4 tracking-tight">
          Find Your <span class="gradient-text">Dream Stay</span>
        </h2>
        <p class="text-slate-500 text-lg">Browse our complete collection of premium homes, villas, and apartments.</p>
      </div>

      <!-- Filters -->
      <form action="/homes" method="GET" class="bg-white p-4 rounded-2xl shadow-sm border border-slate-200 mb-10 flex flex-wrap gap-4 items-end">
        <div class="flex-grow min-w-[150px]">
          <label class="block text-sm font-medium text-slate-600 mb-1">Search / Location</label>
          <input type="text" name="search" value="<%= query && (query.search || query.location) ? (query.search || query.location) : '' %>" placeholder="Where to?" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500">
        </div>
        <div class="w-24">
          <label class="block text-sm font-medium text-slate-600 mb-1">Min Price</label>
          <input type="number" name="minPrice" value="<%= query && query.minPrice ? query.minPrice : '' %>" placeholder="Rs" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500">
        </div>
        <div class="w-24">
          <label class="block text-sm font-medium text-slate-600 mb-1">Max Price</label>
          <input type="number" name="maxPrice" value="<%= query && query.maxPrice ? query.maxPrice : '' %>" placeholder="Rs" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500">
        </div>
        <div class="w-24">
          <label class="block text-sm font-medium text-slate-600 mb-1">Bedrooms</label>
          <input type="number" name="bedrooms" value="<%= query && query.bedrooms ? query.bedrooms : '' %>" min="1" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500">
        </div>
        <div class="w-24">
          <label class="block text-sm font-medium text-slate-600 mb-1">Guests</label>
          <input type="number" name="guests" value="<%= query && query.guests ? query.guests : '' %>" min="1" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500">
        </div>
        <button type="submit" class="btn-gradient text-white px-6 py-2 rounded-lg font-bold h-[42px] flex items-center gap-2">
          <i class="fa-solid fa-filter"></i> Filter
        </button>
        <a href="/homes" class="bg-slate-100 text-slate-600 hover:bg-slate-200 px-6 py-2 rounded-lg font-bold h-[42px] flex items-center transition-colors">
          Clear
        </a>
      </form>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        <% registeredHomes.forEach(home => { %>
          <div class="bg-white rounded-2xl overflow-hidden card-hover border border-slate-100 relative group flex flex-col h-full">
            <a href="/homes/<%= home._id %>" class="block flex-grow">
              <div class="relative h-56 overflow-hidden">
                <img src="/<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
                  <i class="fa-solid fa-star text-yellow-500 text-sm"></i>
                  <span class="font-bold text-slate-800 text-sm"><%= home.rating %></span>
                </div>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <h3 class="text-xl font-bold text-slate-800 truncate mb-1"><%= home.houseName %></h3>
                <p class="text-slate-500 mb-4 flex items-center text-sm font-medium">
                  <i class="fa-solid fa-location-dot mr-2 text-slate-400"></i><%= home.location %>
                </p>
                <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center">
                  <div>
                    <span class="text-2xl font-extrabold text-slate-800">Rs <%= home.price %></span>
                    <span class="text-slate-500 text-sm font-medium"> / night</span>
                  </div>
                </div>
              </div>
            </a>
            <div class="px-6 pb-6 pt-0 flex gap-3">
              <a href="/homes/<%= home._id %>" class="btn-gradient text-white flex-1 text-center py-3 rounded-xl font-bold">
                Details
              </a>
              <form action="/favourites" method="POST" class="flex-none">
                <input type="hidden" name="id" value="<%= home._id %>">
                <button type="submit" class="bg-rose-50 text-rose-600 hover:bg-rose-100 p-3 rounded-xl transition-colors h-full flex items-center justify-center w-12">
                  <i class="fa-solid fa-heart"></i>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>
