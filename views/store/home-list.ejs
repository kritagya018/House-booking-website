<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main style="max-width: 1320px; margin: 0 auto; padding: 2rem 1.5rem;">
      <!-- Page Header -->
      <div style="text-align: center; margin-bottom: 2rem;">
        <h1 style="font-size: 2.2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.5rem; letter-spacing: -0.02em;">Explore <span class="brand-text">Stays</span></h1>
        <p style="color: var(--text-muted); font-size: 0.95rem;">Browse our complete collection of premium properties</p>
      </div>

      <!-- Search & Filters -->
      <form action="/homes" method="GET" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 1rem; padding: 1.25rem; margin-bottom: 2rem;">
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end;">
          <div style="flex: 2; min-width: 180px;">
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">Search</label>
            <input type="text" name="search" value="<%= query && (query.search || query.location) ? (query.search || query.location) : '' %>" placeholder="Location or property name..." class="form-input">
          </div>
          <div style="flex: 1; min-width: 100px;">
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">Min Price</label>
            <input type="number" name="minPrice" value="<%= query && query.minPrice ? query.minPrice : '' %>" placeholder="₹" class="form-input">
          </div>
          <div style="flex: 1; min-width: 100px;">
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">Max Price</label>
            <input type="number" name="maxPrice" value="<%= query && query.maxPrice ? query.maxPrice : '' %>" placeholder="₹" class="form-input">
          </div>
          <div style="flex: 1; min-width: 90px;">
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">Bedrooms</label>
            <input type="number" name="bedrooms" value="<%= query && query.bedrooms ? query.bedrooms : '' %>" min="1" placeholder="Any" class="form-input">
          </div>
          <div style="flex: 1; min-width: 90px;">
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">Guests</label>
            <input type="number" name="guests" value="<%= query && query.guests ? query.guests : '' %>" min="1" placeholder="Any" class="form-input">
          </div>
          <button type="submit" class="btn-primary" style="height: 44px;"><i class="fa-solid fa-search"></i> Search</button>
          <a href="/homes" class="btn-secondary" style="height: 44px; text-decoration: none;">Clear</a>
        </div>
      </form>

      <!-- Results -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
        <p style="font-size: 0.85rem; color: var(--text-muted);"><%= registeredHomes.length %> properties found</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1.5rem;">
        <% registeredHomes.forEach(home => { %>
          <div class="stay-card" style="display: flex; flex-direction: column;">
            <a href="/homes/<%= home._id %>" style="display: block; text-decoration: none; color: inherit; flex: 1;">
              <div style="position: relative; height: 200px; overflow: hidden;">
                <img src="/<%= home.photo %>" alt="<%= home.houseName %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease;">
                <div style="position: absolute; top: 0.75rem; right: 0.75rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); padding: 0.3rem 0.6rem; border-radius: 0.5rem; display: flex; align-items: center; gap: 0.3rem;">
                  <i class="fa-solid fa-star" style="color: #f59e0b; font-size: 0.7rem;"></i>
                  <span style="font-weight: 700; color: white; font-size: 0.8rem;"><%= ratingMap[home._id.toString()] ? ratingMap[home._id.toString()].avg.toFixed(1) : home.rating %></span>
                </div>
                <% if (isLoggedIn && user && user.userType === 'guest') { %>
                  <button class="heart-btn <%= userFavs.includes(home._id.toString()) ? 'active' : '' %>" 
                    onclick="toggleFav(event, '<%= home._id %>', this)"
                    style="position: absolute; top: 0.75rem; left: 0.75rem; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); border: none; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; cursor: pointer;">
                    <i class="fa-<%= userFavs.includes(home._id.toString()) ? 'solid' : 'regular' %> fa-heart" style="color: <%= userFavs.includes(home._id.toString()) ? '#ef4444' : 'white' %>;"></i>
                  </button>
                <% } %>
              </div>
              <div style="padding: 1.25rem;">
                <h3 style="font-size: 1.05rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.35rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= home.houseName %></h3>
                <p style="font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.75rem;">
                  <i class="fa-solid fa-location-dot" style="color: var(--primary);"></i> <%= home.location %>
                </p>
                <div style="display: flex; gap: 0.75rem; margin-bottom: 1rem;">
                  <span style="font-size: 0.75rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.3rem;"><i class="fa-solid fa-bed"></i> <%= home.bedrooms %></span>
                  <span style="font-size: 0.75rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.3rem;"><i class="fa-solid fa-users"></i> <%= home.guests %></span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 0.75rem; border-top: 1px solid var(--border);">
                  <div>
                    <span style="font-size: 1.2rem; font-weight: 800; color: var(--text-primary);">₹<%= home.price.toLocaleString() %></span>
                    <span style="font-size: 0.8rem; color: var(--text-muted);"> / night</span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <div style="text-align: center; padding: 4rem 2rem; background: var(--bg-card); border-radius: 1rem; border: 1px solid var(--border);">
          <i class="fa-solid fa-search" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;"></i>
          <p style="font-size: 1.2rem; color: var(--text-secondary); margin-bottom: 0.5rem;">No properties found</p>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Try adjusting your search filters</p>
          <a href="/homes" class="btn-primary" style="text-decoration: none;">Clear Filters</a>
        </div>
      <% } %>
    </main>

    <script>
      function toggleFav(e, homeId, btn) {
        e.preventDefault();
        e.stopPropagation();
        fetch('/favourites', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: homeId })
        })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            const icon = btn.querySelector('i');
            if (data.action === 'added') {
              btn.classList.add('active');
              icon.className = 'fa-solid fa-heart';
              icon.style.color = '#ef4444';
            } else {
              btn.classList.remove('active');
              icon.className = 'fa-regular fa-heart';
              icon.style.color = 'white';
            }
          }
        }).catch(() => {});
      }
    </script>
  </body>
</html>
