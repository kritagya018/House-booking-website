<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main style="max-width: 520px; margin: 0 auto; padding: 2rem 1.5rem;">
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 1.25rem; padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
          <div style="width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.4rem; color: white; margin: 0 auto 1rem;" class="brand-gradient">S</div>
          <h1 style="font-size: 1.6rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.3rem;">Create your account</h1>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Join StayEG and start exploring</p>
        </div>

        <form action="/signup" method="POST">
          <%- include('../partials/errors') %>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">First Name</label>
              <input type="text" name="firstName" value="<%= oldInput.firstName ? oldInput.firstName : '' %>" placeholder="John" class="form-input" required>
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">Last Name</label>
              <input type="text" name="lastName" value="<%= oldInput.lastName ? oldInput.lastName : '' %>" placeholder="Doe" class="form-input">
            </div>
          </div>

          <div style="margin-bottom: 1rem;">
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">Email Address</label>
            <input type="email" name="email" value="<%= oldInput.email ? oldInput.email : '' %>" placeholder="your@email.com" class="form-input" required>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">Password</label>
              <input type="password" name="password" placeholder="Min 8 characters" class="form-input" required>
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">Confirm Password</label>
              <input type="password" name="confirmPassword" placeholder="Repeat password" class="form-input" required>
            </div>
          </div>

          <!-- User Type -->
          <div style="margin-bottom: 1.25rem;">
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.5rem;">I want to join as</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              <label style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.75rem; cursor: pointer; transition: all 0.2s;" class="user-type-option">
                <input type="radio" name="userType" value="guest" style="accent-color: var(--primary);" <%= oldInput.userType !== 'host' ? 'checked' : '' %>>
                <div>
                  <div style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem;"><i class="fa-solid fa-user" style="margin-right: 0.3rem;"></i> Guest</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted);">Book stays</div>
                </div>
              </label>
              <label style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.75rem; cursor: pointer; transition: all 0.2s;" class="user-type-option">
                <input type="radio" name="userType" value="host" style="accent-color: var(--primary);" <%= oldInput.userType === 'host' ? 'checked' : '' %>>
                <div>
                  <div style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem;"><i class="fa-solid fa-key" style="margin-right: 0.3rem;"></i> Host</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted);">List properties</div>
                </div>
              </label>
            </div>
          </div>

          <!-- Terms -->
          <div style="margin-bottom: 1.5rem;">
            <label style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
              <input type="checkbox" name="terms" style="accent-color: var(--primary); margin-top: 0.15rem; width: 16px; height: 16px;" required>
              <span style="font-size: 0.85rem; color: var(--text-muted);">I agree to the <a href="#" style="color: var(--primary); text-decoration: none;">Terms of Service</a> and <a href="#" style="color: var(--primary); text-decoration: none;">Privacy Policy</a></span>
            </label>
          </div>

          <button type="submit" class="btn-primary" style="width: 100%; padding: 0.85rem; font-size: 1rem;">
            Create Account <i class="fa-solid fa-arrow-right" style="margin-left: 0.3rem;"></i>
          </button>

          <p style="text-align: center; margin-top: 1.5rem; color: var(--text-muted); font-size: 0.9rem;">
            Already have an account? <a href="/login" style="color: var(--primary); font-weight: 600; text-decoration: none;">Sign in</a>
          </p>
        </form>
      </div>
    </main>
  </body>
</html>
