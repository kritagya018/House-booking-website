<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main style="max-width: 480px; margin: 0 auto; padding: 3rem 1.5rem;">
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 1.25rem; padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
          <div style="width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.4rem; color: white; margin: 0 auto 1rem;" class="brand-gradient">S</div>
          <h1 style="font-size: 1.6rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.3rem;">Welcome back</h1>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Sign in to your StayEG account</p>
        </div>

        <form action="/login" method="POST">
          <%- include('../partials/errors') %>
          
          <div style="margin-bottom: 1.25rem;">
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">Email Address</label>
            <div style="position: relative;">
              <i class="fa-solid fa-envelope" style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.85rem;"></i>
              <input type="email" name="email" value="<%= oldInput.email ? oldInput.email : '' %>" placeholder="your@email.com" class="form-input" style="padding-left: 2.5rem;" required>
            </div>
          </div>

          <div style="margin-bottom: 1.75rem;">
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem;">Password</label>
            <div style="position: relative;">
              <i class="fa-solid fa-lock" style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.85rem;"></i>
              <input type="password" name="password" placeholder="Enter your password" class="form-input" style="padding-left: 2.5rem;" required>
            </div>
          </div>

          <button type="submit" class="btn-primary" style="width: 100%; padding: 0.85rem; font-size: 1rem;">
            Sign In <i class="fa-solid fa-arrow-right" style="margin-left: 0.3rem;"></i>
          </button>

          <!-- 1-Click Demo Logins -->
          <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
            <p style="text-align: center; color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Or use a demo account</p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              <button type="button" onclick="loginAsDemo('guest@stayeg.com', 'Password@123')" class="btn-secondary" style="font-size: 0.85rem; padding: 0.75rem;">
                <i class="fa-solid fa-user" style="color: var(--primary);"></i> Demo Guest
              </button>
              <button type="button" onclick="loginAsDemo('host@stayeg.com', 'Password@123')" class="btn-secondary" style="font-size: 0.85rem; padding: 0.75rem;">
                <i class="fa-solid fa-key" style="color: var(--warning);"></i> Demo Host
              </button>
            </div>
          </div>

          <p style="text-align: center; margin-top: 1.5rem; color: var(--text-muted); font-size: 0.9rem;">
            Don't have an account? <a href="/signup" style="color: var(--primary); font-weight: 600; text-decoration: none;">Create one</a>
          </p>
        </form>
      </div>
    </main>

    <script>
      function loginAsDemo(email, password) {
        document.querySelector('input[name="email"]').value = email;
        document.querySelector('input[name="password"]').value = password;
        document.querySelector('form').submit();
      }
    </script>
  </body>
</html>
