<header class="glass-nav sticky top-0 z-50 transition-all duration-300">
  <nav class="container mx-auto px-6 py-4">
    <div class="hidden md:flex md:justify-between md:items-center">
      <!-- Logo -->
      <a href="/" class="flex items-center text-3xl font-extrabold gradient-text tracking-tight hover:opacity-80 transition-opacity">
        <i class="fa-brands fa-airbnb mr-2"></i>
        airbnb<span class="text-slate-800 font-light ml-1">Luxe</span>
      </a>

      <!-- Navigation Links -->
      <ul class="flex items-center gap-6">
        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'guest') { %>
            <li><a href="/homes" class="<%= currentPage === 'Home' ? 'text-rose-600 font-bold' : 'text-slate-600 hover:text-rose-500' %> transition-colors font-medium text-lg">Homes</a></li>
            <li><a href="/favourites" class="<%= currentPage === 'favourites' ? 'text-rose-600 font-bold' : 'text-slate-600 hover:text-rose-500' %> transition-colors font-medium text-lg">Favourites</a></li>
            <li><a href="/bookings" class="<%= currentPage === 'bookings' ? 'text-rose-600 font-bold' : 'text-slate-600 hover:text-rose-500' %> transition-colors font-medium text-lg">Bookings</a></li>
          <% } else { %>
            <li><a href="/host/host-home-list" class="<%= currentPage === 'host-homes' ? 'text-rose-600 font-bold' : 'text-slate-600 hover:text-rose-500' %> transition-colors font-medium text-lg">Host Homes</a></li>
            <li><a href="/host/add-home" class="<%= currentPage === 'addHome' ? 'text-rose-600 font-bold' : 'text-slate-600 hover:text-rose-500' %> transition-colors font-medium text-lg">Add Home</a></li>
          <% } %>
        <% } %>
      </ul>

      <!-- Auth Buttons -->
      <ul class="flex items-center gap-4">
        <% if (!isLoggedIn) { %>
          <li><a href="/login" class="text-slate-800 hover:text-rose-600 font-medium transition-colors">Log in</a></li>
          <li><a href="/signup" class="btn-gradient text-white px-6 py-2.5 rounded-full font-bold shadow-md">Sign up</a></li>
        <% } else { %>
          <li>
            <form action="/logout" method="POST">
              <button type="submit" class="border-2 border-slate-200 text-slate-700 hover:border-rose-500 hover:text-rose-600 px-6 py-2 rounded-full font-bold transition-all flex items-center gap-2">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
              </button>
            </form>
          </li>
        <% } %>
      </ul>
    </div>

    <!-- Mobile Navigation (Simplified) -->
    <div class="md:hidden flex justify-between items-center">
      <a href="/" class="flex items-center text-2xl font-extrabold gradient-text">
        <i class="fa-brands fa-airbnb mr-2"></i>
        airbnb<span class="text-slate-800 font-light ml-1">Luxe</span>
      </a>
      <button id="mobile-menu-button" class="text-slate-800 text-2xl">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
  </nav>
</header>
