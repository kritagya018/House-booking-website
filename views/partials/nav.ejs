<header class="glass-nav sticky top-0 z-50">
  <nav style="max-width: 1320px; margin: 0 auto; padding: 0.8rem 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <!-- Logo -->
      <a href="/" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
        <div style="width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.1rem; color: white;" class="brand-gradient">S</div>
        <span style="font-size: 1.4rem; font-weight: 800; color: var(--text-primary); letter-spacing: -0.02em;">Stay<span class="brand-text">EG</span></span>
      </a>

      <!-- Desktop Navigation -->
      <div class="desktop-nav" style="display: flex; align-items: center; gap: 0.5rem;">
        <a href="/" style="padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.2s; <%= currentPage === 'index' ? 'color: var(--primary); background: rgba(16,185,129,0.08);' : 'color: var(--text-secondary);' %>">Home</a>
        <a href="/homes" style="padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.2s; <%= currentPage === 'Home' ? 'color: var(--primary); background: rgba(16,185,129,0.08);' : 'color: var(--text-secondary);' %>">Explore</a>
        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'guest') { %>
            <a href="/favourites" style="padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.2s; <%= currentPage === 'favourites' ? 'color: var(--primary); background: rgba(16,185,129,0.08);' : 'color: var(--text-secondary);' %>">Favourites</a>
            <a href="/bookings" style="padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.2s; <%= currentPage === 'bookings' ? 'color: var(--primary); background: rgba(16,185,129,0.08);' : 'color: var(--text-secondary);' %>">Bookings</a>
          <% } else { %>
            <a href="/host/host-home-list" style="padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.2s; <%= currentPage === 'host-homes' ? 'color: var(--primary); background: rgba(16,185,129,0.08);' : 'color: var(--text-secondary);' %>">My Properties</a>
            <a href="/host/add-home" style="padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.2s; <%= currentPage === 'addHome' ? 'color: var(--primary); background: rgba(16,185,129,0.08);' : 'color: var(--text-secondary);' %>">List Property</a>
          <% } %>
        <% } %>
      </div>

      <!-- Right Side -->
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <% if (isLoggedIn) { %>
          <!-- Notification Bell -->
          <a href="/notifications" style="position: relative; color: var(--text-secondary); font-size: 1.1rem; text-decoration: none; padding: 0.5rem; transition: color 0.2s; <%= currentPage === 'notifications' ? 'color: var(--primary);' : '' %>" id="notif-bell">
            <i class="fa-solid fa-bell"></i>
            <span class="notif-dot" id="notif-count" style="display: none;">0</span>
          </a>

          <!-- User Menu -->
          <div style="position: relative;" id="user-menu-container">
            <button id="user-menu-btn" style="display: flex; align-items: center; gap: 0.6rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 9999px; padding: 0.35rem 0.8rem 0.35rem 0.35rem; cursor: pointer; transition: all 0.2s;">
              <div class="avatar" style="width: 32px; height: 32px; font-size: 0.75rem;">
                <% if (user && user.avatar) { %>
                  <img src="/<%= user.avatar %>" alt="" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                <% } else { %>
                  <%= user ? user.firstName.charAt(0).toUpperCase() : 'U' %>
                <% } %>
              </div>
              <span style="font-size: 0.85rem; font-weight: 500; color: var(--text-primary); max-width: 100px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= user ? user.firstName : '' %></span>
              <i class="fa-solid fa-chevron-down" style="font-size: 0.65rem; color: var(--text-muted);"></i>
            </button>
            <div class="dropdown-menu" id="user-dropdown">
              <a href="/profile" class="dropdown-item">
                <i class="fa-solid fa-user" style="width: 16px; text-align: center;"></i> Profile
              </a>
              <a href="/notifications" class="dropdown-item">
                <i class="fa-solid fa-bell" style="width: 16px; text-align: center;"></i> Notifications
              </a>
              <% if (user && user.userType === 'guest') { %>
                <a href="/bookings" class="dropdown-item">
                  <i class="fa-solid fa-calendar-check" style="width: 16px; text-align: center;"></i> My Bookings
                </a>
                <a href="/favourites" class="dropdown-item">
                  <i class="fa-solid fa-heart" style="width: 16px; text-align: center;"></i> Favourites
                </a>
              <% } %>
              <a href="/settings" class="dropdown-item">
                <i class="fa-solid fa-gear" style="width: 16px; text-align: center;"></i> Settings
              </a>
              <div class="dropdown-divider"></div>
              <form action="/logout" method="POST" style="margin: 0;">
                <button type="submit" class="dropdown-item" style="width: 100%; background: none; border: none; cursor: pointer; font-family: inherit; font-size: inherit; color: var(--danger);">
                  <i class="fa-solid fa-arrow-right-from-bracket" style="width: 16px; text-align: center;"></i> Sign Out
                </button>
              </form>
            </div>
          </div>
        <% } else { %>
          <a href="/login" style="color: var(--text-secondary); font-weight: 500; font-size: 0.9rem; text-decoration: none; padding: 0.5rem 1rem; transition: color 0.2s;">Sign In</a>
          <a href="/signup" class="btn-primary" style="padding: 0.55rem 1.4rem; font-size: 0.85rem; border-radius: 9999px; text-decoration: none;">Get Started</a>
        <% } %>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-toggle" style="display: none; background: none; border: none; color: var(--text-primary); font-size: 1.3rem; cursor: pointer; padding: 0.5rem;">
          <i class="fa-solid fa-bars"></i>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu" id="mobile-menu">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <a href="/" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
      <div style="width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.1rem; color: white;" class="brand-gradient">S</div>
      <span style="font-size: 1.4rem; font-weight: 800; color: var(--text-primary);">Stay<span class="brand-text">EG</span></span>
    </a>
    <button id="mobile-close" style="background: none; border: none; color: var(--text-primary); font-size: 1.5rem; cursor: pointer;">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>
  <div style="display: flex; flex-direction: column; gap: 0.5rem; flex: 1;">
    <a href="/" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary); transition: all 0.2s;"><i class="fa-solid fa-house" style="width: 24px; margin-right: 0.75rem;"></i>Home</a>
    <a href="/homes" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary); transition: all 0.2s;"><i class="fa-solid fa-compass" style="width: 24px; margin-right: 0.75rem;"></i>Explore</a>
    <% if (isLoggedIn) { %>
      <% if (user && user.userType === 'guest') { %>
        <a href="/favourites" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-heart" style="width: 24px; margin-right: 0.75rem;"></i>Favourites</a>
        <a href="/bookings" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-calendar-check" style="width: 24px; margin-right: 0.75rem;"></i>Bookings</a>
      <% } else { %>
        <a href="/host/host-home-list" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-building" style="width: 24px; margin-right: 0.75rem;"></i>My Properties</a>
        <a href="/host/add-home" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-plus" style="width: 24px; margin-right: 0.75rem;"></i>List Property</a>
      <% } %>
      <a href="/notifications" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-bell" style="width: 24px; margin-right: 0.75rem;"></i>Notifications</a>
      <a href="/profile" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-user" style="width: 24px; margin-right: 0.75rem;"></i>Profile</a>
      <a href="/settings" style="padding: 1rem; border-radius: 0.75rem; font-size: 1.05rem; font-weight: 500; text-decoration: none; color: var(--text-secondary);"><i class="fa-solid fa-gear" style="width: 24px; margin-right: 0.75rem;"></i>Settings</a>
      <div style="margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border);">
        <form action="/logout" method="POST">
          <button type="submit" style="width: 100%; padding: 1rem; border-radius: 0.75rem; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: var(--danger); font-size: 1rem; font-weight: 600; cursor: pointer; font-family: inherit;"><i class="fa-solid fa-arrow-right-from-bracket" style="margin-right: 0.75rem;"></i>Sign Out</button>
        </form>
      </div>
    <% } else { %>
      <div style="margin-top: auto; display: flex; flex-direction: column; gap: 0.75rem;">
        <a href="/login" class="btn-secondary" style="text-align: center; text-decoration: none; padding: 0.85rem; border-radius: 0.75rem;">Sign In</a>
        <a href="/signup" class="btn-primary" style="text-align: center; text-decoration: none; padding: 0.85rem; border-radius: 0.75rem;">Get Started</a>
      </div>
    <% } %>
  </div>
</div>

<script>
  // User dropdown
  const userMenuBtn = document.getElementById('user-menu-btn');
  const userDropdown = document.getElementById('user-dropdown');
  if (userMenuBtn && userDropdown) {
    userMenuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      userDropdown.classList.toggle('active');
    });
    document.addEventListener('click', () => userDropdown.classList.remove('active'));
  }

  // Mobile menu
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileClose = document.getElementById('mobile-close');
  if (mobileToggle) {
    mobileToggle.addEventListener('click', () => mobileMenu.classList.add('active'));
  }
  if (mobileClose) {
    mobileClose.addEventListener('click', () => mobileMenu.classList.remove('active'));
  }

  // Fetch notification count
  <% if (isLoggedIn) { %>
  fetch('/api/notifications/count')
    .then(r => r.json())
    .then(data => {
      const badge = document.getElementById('notif-count');
      if (badge && data.count > 0) {
        badge.style.display = 'flex';
        badge.textContent = data.count > 9 ? '9+' : data.count;
      }
    }).catch(() => {});
  <% } %>

  // Responsive: show mobile toggle on small screens
  const mediaQuery = window.matchMedia('(max-width: 768px)');
  function handleResize(e) {
    const desktopNav = document.querySelector('.desktop-nav');
    const mobileBtn = document.getElementById('mobile-toggle');
    if (e.matches) {
      if (desktopNav) desktopNav.style.display = 'none';
      if (mobileBtn) mobileBtn.style.display = 'block';
    } else {
      if (desktopNav) desktopNav.style.display = 'flex';
      if (mobileBtn) mobileBtn.style.display = 'none';
      if (mobileMenu) mobileMenu.classList.remove('active');
    }
  }
  mediaQuery.addEventListener('change', handleResize);
  handleResize(mediaQuery);
</script>
