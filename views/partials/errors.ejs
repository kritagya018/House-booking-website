<% if (errors && errors.length > 0) { %>
  <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); border-radius: 0.75rem; padding: 1rem; margin-bottom: 1.25rem;">
    <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
      <i class="fa-solid fa-exclamation-triangle" style="color: var(--danger); margin-top: 0.15rem;"></i>
      <div>
        <% errors.forEach(error => { %>
          <p style="color: #fca5a5; font-size: 0.85rem; margin-bottom: 0.2rem;"><%= error %></p>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>